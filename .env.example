# Proxy service
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# DigitalOcean Serverless Inference (OpenAI-compatible)
# https://inference.do-ai.run/v1/chat/completions
PRIMARY_LLM_BASE_URL=https://inference.do-ai.run/v1
PRIMARY_LLM_MODEL=llama3.3-70b-instruct
PRIMARY_LLM_API_KEY=

CANDIDATE_LLM_BASE_URL=https://inference.do-ai.run/v1
CANDIDATE_LLM_MODEL=llama3-8b-instruct
CANDIDATE_LLM_API_KEY=

# Set to false to call real DigitalOcean Serverless Inference
MOCK_LLM=false

# Request timeout (seconds) for upstream LLM calls
LLM_TIMEOUT_SECONDS=60

# Shadow pool bounds (load shedding when queue + threads saturated)
SHADOW_CORE_POOL_SIZE=4
SHADOW_MAX_POOL_SIZE=16
SHADOW_QUEUE_CAPACITY=500
MAX_COMPARISON_RECORDS=1000
